{
	"name": "obsidian-simplejs-plugin",
	"version": "1.0.0",
	"description": "SimpleJS Plots for Obsidian - Execute JavaScript snippets and create interactive plots with Plotly",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": ["obsidian", "plugin", "plots", "plotly", "visualization", "data"],
	"author": "",
	"license": "MIT",
	"dependencies": {
		"js-yaml": "^4.1.0",
		"papaparse": "^5.4.1",
		"plotly.js-dist-min": "^2.26.0"
	},
	"devDependencies": {
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^16.11.6",
		"@types/papaparse": "^5.3.14",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
